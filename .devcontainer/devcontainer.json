{
    "name": "Eidolon.jl (Claude YOLO sandbox)",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "TZ": "${localEnv:TZ:Europe/Oslo}",
            "JULIA_VERSION": "1.11"
        }
    },
    "runArgs": [
        "--cap-add=NET_ADMIN",
        "--cap-add=NET_RAW"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "anthropic.claude-code",
                "julialang.language-julia",
                "eamodio.gitlens"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh",
                "editor.formatOnSave": false,
                "julia.executablePath": "/usr/local/julia/bin/julia"
            }
        }
    },
    "remoteUser": "node",
    "mounts": [
        "source=eidolon-bashhistory,target=/commandhistory,type=volume",
        "source=eidolon-claude-config,target=/home/node/.claude,type=volume",
        "source=eidolon-julia-depot,target=/home/node/.julia,type=volume"
    ],
    "remoteEnv": {
        "NODE_OPTIONS": "--max-old-space-size=4096",
        "CLAUDE_CONFIG_DIR": "/home/node/.claude",
        "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
        "JULIA_DEPOT_PATH": "/home/node/.julia",
        "JULIA_NUM_THREADS": "auto"
    },
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
    "workspaceFolder": "/workspace",
    "postCreateCommand": "sudo /usr/local/bin/init-firewall.sh && julia --project=. -e 'using Pkg; Pkg.status()' 2>/dev/null || true"
}
